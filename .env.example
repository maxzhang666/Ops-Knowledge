# .env.example — only 3 bootstrap items, all other config via UI
DATABASE_URL=postgresql+asyncpg://opsknowledge:opsknowledge@localhost:5432/ops_knowledge
REDIS_URL=redis://localhost:6379/0
JWT_SECRET_KEY=change-this-to-a-random-secret-key-in-production


# --- Workflow engine (Plan 29 migration) ---
# Engine selection: "legacy" = in-house DAGScheduler; "langgraph" = new engine.
# Keep on "legacy" until Phase 5 grey-release.
WORKFLOW_ENGINE=legacy

# Disable LangChain/LangSmith tracing. Our observability goes through Langfuse.
# app/core/config.py sets this as default via os.environ.setdefault; declaring
# it here makes the expectation explicit for deployers.
LANGCHAIN_TRACING_V2=false

# ── Langfuse 可观测性（Spec 05 规定 env-only） ─────────────────────────
  # 四项都设置才启用；留空则 client 走 no-op。修改后需重启 API 进程。
  LANGFUSE_HOST=
  LANGFUSE_PUBLIC_KEY=
  LANGFUSE_SECRET_KEY=
  LANGFUSE_CAPTURE_IO=false